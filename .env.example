# Anthropic API (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# CoinTracking API (required for crypto portfolio sync)
# Generate at: https://cointracking.info/profile/api.php
# Create a read-only key — no trading permissions needed
COINTRACKING_API_KEY=your_cointracking_api_key_here
COINTRACKING_API_SECRET=your_cointracking_api_secret_here

# Finnhub (optional — for live news feed)
# Free tier at: https://finnhub.io
FINNHUB_API_KEY=

# Server port (default 3001 — do not change unless you have a conflict)
PORT=3001
